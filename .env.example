# STT
DEEPGRAM_API_KEY=
# TTS
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=cgSgspJ2msm6clMCkdW9   # Jessica
# 내부 서비스 URL
LLM_URL=http://localhost:8000      # ② moly-llm
SERVER_URL=                         # ① moly-server (세션·영속)
# 세션시작 메모리 로드 타임아웃(초). mem0 콜드/스파이크로 5s 초과 시 ReadTimeout 방지(기본 12).
MEMORY_LOAD_TIMEOUT_S=12
# end 후 STT 최종 transcript 대기 상한(ms). EC2 등 고지연 환경에서 너무 짧으면 빈 결과로 떨어짐.
STT_FINALIZE_GRACE_MS=2000
# STT provider: deepgram(기본) | elevenlabs(Scribe v2 RT) | soniox
STT_PROVIDER=deepgram
# 인식 언어(영어회화 앱 — en 고정). provider 공통.
STT_LANGUAGE=en

# ── WS 인증 (Supabase) ── server와 같은 값. 둘 다 공개값.
SUPABASE_URL=
SUPABASE_ANON_KEY=
# 프로덕션 true(토큰 필수). 로컬/데모 false(DEMO 폴백 허용). 프론트 로그인 붙으면 prod에서 true.
REQUIRE_AUTH=false

# 선발화: true(기본)면 새 세션에서 Moly가 먼저 인사. 끄려면 false.
GREETING_ENABLED=true

# ── 남용 방어(연결당) ── per-IP/전역 연결 cap은 앞단 프록시(ALB/nginx) 영역.
SESSION_INIT_TIMEOUT_S=10
MAX_TEXT_LEN=4000
MAX_HISTORY_ITEMS=200
MAX_HISTORY_BYTES=200000
MAX_TURNS_PER_MIN=30

# ── 내부 호출 보호(심층방어) ── moly-llm과 동일값. 비우면 미강제(로컬).
INTERNAL_SERVICE_TOKEN=

# ── 에러 알림 ── Slack Incoming Webhook URL. 비우면 알림 끔(로컬 안전).
SLACK_WEBHOOK_URL=
